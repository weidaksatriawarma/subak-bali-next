# REQUIRED — Supabase project credentials (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# REQUIRED — AI Gateway API key for Claude/GPT model routing
AI_GATEWAY_API_KEY=your-api-key

# OPTIONAL — Production URL for OAuth redirects (falls back to window.location.origin)
NEXT_PUBLIC_APP_URL=https://subakhijau.app

# OPTIONAL — Secret for seeding demo data in production (leave blank to disable)
SEED_SECRET=
